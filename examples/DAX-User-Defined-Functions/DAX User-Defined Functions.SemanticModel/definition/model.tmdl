model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: es-CO
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["financials"]

annotation PBI_ProTooling = ["MCP-PBIModeling","TMDLView_Desktop","DevMode"]

ref table financials
ref table _Medidas

ref cultureInfo en-US

